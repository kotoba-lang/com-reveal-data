// Reveal_data clean-room schema -> Datomic EAVT mapping
// Generated by deepen_actors.py (ADR 260607 deepening phase).

namespace reveal_data {

    entity Matter {
        id: string @unique
        clientId: string
        name: string
        status: string
        openedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

    entity Document {
        id: string @unique
        matterId: string
        custodianId: string
        contentRef: string
        reviewStatus: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Custodian {
        id: string @unique
        matterId: string
        name: string
        email: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity Review {
        id: string @unique
        documentId: string
        reviewerId: string
        coding: string
        createdAt: datetime
        updatedAt: datetime
    }

    entity ProductionSet {
        id: string @unique
        matterId: string
        name: string
        documentCount: integer
        createdAt: datetime
        updatedAt: datetime
    }

    entity LegalHold {
        id: string @unique
        matterId: string
        custodianId: string
        status: string
        issuedAt: datetime
        createdAt: datetime
        updatedAt: datetime
    }

}

    // Auto-injected Cognitive Schema
    entity CognitiveRecord {
        id: string @unique
        originalPayload: string
        aiStatus: string
        aiInsights: json
        computedAt: datetime
    }
